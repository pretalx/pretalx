# SPDX-FileCopyrightText: 2023-present NONE
# SPDX-License-Identifier: CC0-1.0

include LICENSE
recursive-include LICENSES *.txt
include README.rst
include src/manage.py
include src/pretalx.example.cfg
include src/pretalx.example.cfg.license
# Build backend; must be in the sdist so a wheel can be built from it.
include _build/backend.py

exclude src/pretalx/override_settings.py
exclude src/pretalx.cfg
exclude justfile
exclude src/pretalx/frontend/schedule-editor/locales/en/translation.po

recursive-exclude doc *
recursive-exclude tools *
recursive-exclude src/data *
recursive-exclude src/local *

recursive-include src/pretalx/static *
recursive-include src/pretalx/locale *
recursive-include src/pretalx/agenda/templates *
recursive-include src/pretalx/api/templates *
recursive-include src/pretalx/common/templates *
recursive-include src/pretalx/cfp/templates *
recursive-include src/pretalx/mail/templates *
recursive-include src/pretalx/orga/templates *
recursive-include src/pretalx/schedule/templates *
recursive-exclude src/tests *
recursive-include src/pretalx *.py
recursive-include src/pretalx *.license

# Frontend block must come last: the node_modules exclude needs to override
# the "recursive-include src/pretalx *.py" above, since later directives take
# precedence, and node_modules can contain Python modules because this is the
# world we made.
recursive-include src/pretalx/frontend *
recursive-exclude src/pretalx/frontend/node_modules *

# We ship schedule and schedule editor prebuilt in wheels, because a
# pip-installed pretalx must work without Node.js/npm on the server. They
# ship differently because the widget is a self-contained web component
# embedded on third-party sites, so it lives in the source static dir and is
# collected like any other static file (static/agenda/js/); the editor and
# same-origin schedule are a manifest-bundled app whose hashed output lives
# in dist/ and is installed into STATIC_ROOT separately.
recursive-include src/pretalx/frontend/schedule-editor/dist *

global-exclude *.py[co]
global-exclude __pycache__
