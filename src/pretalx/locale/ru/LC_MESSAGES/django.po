msgstr "Посмотреть расписание конференции"

#: pretalx/agenda/phrases.py
msgid "View schedule preview"
msgstr "Предварительный просмотр расписания"

#: pretalx/agenda/phrases.py
msgid "Edit or view your proposals"
msgstr "Редактируйте или просматривайте свои предложения"

