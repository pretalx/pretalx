#: pretalx/submission/models/resource.py
msgid "Resources"
msgstr "Матеріали"

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please write between {min_length} and {max_length} words."
msgstr "Будь ласка, напишіть від {min_length} до {max_length} слів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please write between {min_length} and {max_length} characters."
msgstr "Будь ласка, напишіть від {min_length} до {max_length} символів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please write at least {min_length} words."
msgstr "Будь ласка, напишіть щонайменше {min_length} слів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please write at least {min_length} characters."
msgstr "Будь ласка, напишіть щонайменше {min_length} символів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please write at most {max_length} words."
msgstr "Будь ласка, напишіть не більше ніж {max_length} слів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please write at most {max_length} characters."
msgstr "Будь ласка, напишіть не більше ніж {max_length} символів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "You wrote {count} characters."
msgstr "Ви написали {count} символів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "You wrote {count} words."
msgstr "Ви написали {count} слів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select exactly {count} tags."
msgstr "Будь ласка, виберіть {count} тегів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select between {min} and {max} tags."
msgstr "Будь ласка, виберіть від {min} до {max} тегів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select at least {min} tags."
msgstr "Будь ласка, виберіть щонайменше {min} тегів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select at most {max} tags."
msgstr "Будь ласка, виберіть не більше ніж {max} тегів."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "You selected {count} tags."
msgstr "Ви обрали {count} тегів."

#: pretalx/cfp/phrases.py
msgid ""
"If we know a user by this email address (who has not requested a password "
"reset in the last 24 hours), we will send you an email containing further "
"instructions. If you don’t see the email within the next minutes, check your "
"spam inbox!"
msgstr ""
"Якщо користувач із цією адресою існує (і не запитував скидання пароля "
"останні 24 години), ми надішлемо лист із інструкціями. Не отримали листа? "
"Перевірте спам!"

#: pretalx/cfp/phrases.py
msgid ""
"This link was not valid. Make sure you copied the complete URL from the "
"email and that the email is no more than 24 hours old."
msgstr ""
"Це посилання недійсне. Переконайтеся, що ви скопіювали повний URL з листа і "
"що листу не більше 24 годин."

#: pretalx/cfp/phrases.py
msgid "Awesome! You can now log in using your new password."
msgstr "Чудово! Тепер ви можете увійти, використовуючи новий пароль."

#: pretalx/cfp/phrases.py
msgid "Your proposal has been withdrawn."
msgstr "Ваша пропозиція була відкликана."

#: pretalx/cfp/phrases.py
msgid ""
"Your proposal can’t be withdrawn at this time – please contact us if you "
"need to withdraw your proposal!"
msgstr ""
"Ваша пропозиція наразі не може бути відкликана — будь ласка, зв’яжіться з "
"нами, якщо потрібно її відкликати!"

#: pretalx/cfp/phrases.py
msgid "Your session has been confirmed – we’re looking forward to seeing you!"
msgstr "Ваша сесія підтверджена — чекаємо на вас із нетерпінням!"

#: pretalx/cfp/phrases.py
msgid ""
"This proposal has already been confirmed – we’re looking forward to seeing "
"you!"
msgstr "Ця пропозиція вже підтверджена — чекаємо на вас із нетерпінням!"

#: pretalx/cfp/phrases.py
msgid ""
"This proposal cannot be confirmed at this time – please contact us if you "
"think this is an error."
msgstr ""
"Цю пропозицію наразі неможливо підтвердити — будь ласка, зв’яжіться з нами, "
"якщо вважаєте, що сталася помилка."

#: pretalx/cfp/phrases.py
msgid ""
"This proposal cannot be edited at this time. Please contact the organisers "
"if you need to make changes."
msgstr ""
"Наразі редагування цієї пропозиції неможливе — зверніться до організаторів "
"для змін."

#: pretalx/cfp/phrases.py
msgctxt "field: speaker's email address"
msgid "Speaker email"
msgstr "Електронна адреса спікера"

#: pretalx/cfp/phrases.py
#, python-brace-format
msgid "{inviting_speaker} invites you to join their session!"
msgstr "{inviting_speaker} запрошує вас приєднатися до своєї сесії!"

#: pretalx/cfp/phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"I’d like to invite you to be a speaker in the session\n"
"\n"
"  “{proposal_title}”\n"
"\n"
"at {event_name}. Please follow this link to join:\n"
"\n"
"  {url}\n"
"\n"
"I’m looking forward to it!\n"
"{inviting_speaker}"
msgstr ""
"Вітаю!\n"
"\n"
"Хочу запросити вас виступити спікером у сесії\n"
"\n"
"  «{proposal_title}»\n"
"\n"
"на заході {event_name}. Будь ласка, перейдіть за цим посиланням, щоб "
"приєднатися:\n"
"\n"
"  {url}\n"
"\n"
"З нетерпінням чекаю!\n"
"{inviting_speaker}"

#: pretalx/cfp/phrases.py
msgid "Please provide a valid email address."
msgstr "Будь ласка, вкажіть дійсну адресу електронної пошти."

#: pretalx/cfp/phrases.py pretalx/orga/views/organiser.py
msgid "The invitation has been sent."
msgstr "Запрошення надіслано."

#: pretalx/cfp/phrases.py
msgid "You are now part of this proposal! Please fill in your profile below."
msgstr ""
"Тепер ви є частиною цієї пропозиції! Будь ласка, заповніть свій профіль "
"нижче."

#: pretalx/cfp/phrases.py
msgid ""
"We are experiencing difficulties when sending emails, but your session was "
"submitted successfully!"
msgstr ""
"Ми стикаємося з труднощами під час надсилання електронних листів, але вашу "
"сесію було успішно подано!"

#: pretalx/cfp/phrases.py pretalx/common/log.py pretalx/orga/views/cfp.py
msgid "Custom fields"
msgstr "Додаткові поля"

#: pretalx/cfp/templates/cfp/event/cfp.html
#, python-format
msgid ""
"Submissions close on %(deadline)s (%(timezone)s), %(until_string)s from now."
msgstr ""
"Подання закривається %(deadline)s (%(timezone)s), %(until_string)s від "
"сьогодні."

#: pretalx/cfp/templates/cfp/event/cfp.html
#, python-format
msgid "Submissions open on %(opening)s (%(timezone)s)."
msgstr "Подання відкривається %(opening)s (%(timezone)s)."

#: pretalx/cfp/templates/cfp/event/cfp.html
#, python-format
msgid "Submissions closed on %(deadline)s (%(timezone)s)."
msgstr "Подання закрите %(deadline)s (%(timezone)s)."

#: pretalx/cfp/templates/cfp/event/cfp.html
#: pretalx/cfp/templates/cfp/event/index.html
msgid "Submit a proposal"
msgstr "Подати пропозицію"

#: pretalx/cfp/templates/cfp/event/cfp.html pretalx/cfp/views/wizard.py
msgid "Proposals are closed"
msgstr "Прийом пропозицій закрито"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/submission/enums.py
msgid "accepted"
msgstr "прийнято"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/orga/views/dashboard.py pretalx/submission/enums.py
msgid "confirmed"
msgstr "підтверджено"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/submission/enums.py
msgid "Cancelled"
msgstr "Скасовано"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/submission/enums.py
msgid "withdrawn"
msgstr "відкликано"

#: pretalx/cfp/templates/cfp/event/index.html
msgid "Go To Organiser Area"
msgstr "Перейти до панелі організатора"

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid "Accept invitation?"
msgstr "Прийняти запрошення?"

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid ""
"Unfortunately, you cannot accept this invitation at the moment. This may be "
"because the invitation has expired, or because the proposal cannot be edited "
"any more."
msgstr ""
"На жаль, ви не можете прийняти це запрошення наразі. Це може бути через те, "
"що запрошення минуло або пропозицію більше не можна редагувати."

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid "Please contact the conference organisers for more information."
msgstr ""
"Будь ласка, зв’яжіться з організаторами конференції для отримання додаткової "
"інформації."

#: pretalx/cfp/templates/cfp/event/invitation.html
#, python-format
msgid ""
"You, %(name)s, have been invited to be a speaker for the session “%(talk)s”. "
"Do you accept the invitation?"
msgstr ""
"Вас, %(name)s, запрошено виступити спікером на сесії «%(talk)s». Ви "
"приймаєте запрошення?"

#: pretalx/cfp/templates/cfp/event/invitation.html
#: pretalx/orga/templates/orga/submission/review.html
#: pretalx/submission/models/submission.py
msgid "Abstract"
msgstr "Анотація"

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid "Accept invitation"
msgstr "Прийняти запрошення"

#: pretalx/cfp/templates/cfp/event/login.html
msgid "Login"
msgstr "Увійти"

#: pretalx/cfp/templates/cfp/event/login.html
msgid "Welcome back!"
msgstr "Ласкаво просимо назад!"

#: pretalx/cfp/templates/cfp/event/login.html
msgid ""
"You do not need an account to view the event, or submit feedback, or receive "
"schedule updates. You’ll only need an account if you participate in the "
"event as speaker or as an organiser."
msgstr ""
"Для перегляду заходу, залишення відгуків або отримання оновлень розкладу "
"акаунт не потрібен. Акаунт знадобиться лише, якщо ви берете участь у заході "
"як спікер або організатор."

#: pretalx/cfp/templates/cfp/event/login.html
msgid ""
"If you already created a proposal for a different event on this server, you "
"can re-use your account to log in for this event."
msgstr ""
"Якщо ви вже створили пропозицію для іншого заходу на цьому сервері, ви "
"можете використати свій акаунт для входу на цей захід."

#: pretalx/cfp/templates/cfp/event/recover.html
msgid "Set your password to access your profile and proposals"
msgstr "Встановіть пароль, щоб отримати доступ до свого профілю та пропозицій"

#: pretalx/cfp/templates/cfp/event/submission_base.html
#: pretalx/orga/templates/orga/submission/content.html
msgid "Create proposal"
msgstr "Створити пропозицію"

#: pretalx/cfp/templates/cfp/event/submission_base.html
msgid "Save as draft"
msgstr "Зберегти як чернетку"

#: pretalx/cfp/templates/cfp/event/submission_base.html
#: pretalx/orga/templates/orga/cfp/editor.html
msgid "Continue"
msgstr "Продовжити"

#: pretalx/cfp/templates/cfp/event/submission_base.html
#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Submit proposal"
msgstr "Подати пропозицію"

#: pretalx/cfp/templates/cfp/event/submission_base.html
msgid "or save as draft for now"
msgstr "або зберегти як чернетку на даний момент"

#: pretalx/cfp/templates/cfp/event/submission_base.html
msgid ""
"You can save your proposal as a draft and submit it later. Organisers will "
"not be able to see your proposal, though they will be able to send you "
"reminder emails about the upcoming deadline."
msgstr ""
"Ви можете зберегти свою пропозицію як чернетку і подати її пізніше. "
"Організатори не зможуть побачити вашу пропозицію, але зможуть надсилати вам "
"нагадування про наближення дедлайну."

#: pretalx/cfp/templates/cfp/event/submission_questions.html
#: pretalx/orga/templates/orga/cfp/editor.html
msgid "… about your proposal:"
msgstr "… про вашу пропозицію:"

#: pretalx/cfp/templates/cfp/event/submission_questions.html
#: pretalx/orga/templates/orga/cfp/editor.html
msgid "… about yourself:"
msgstr "… про себе:"

#: pretalx/cfp/templates/cfp/event/submission_user.html
msgid "Log in or register to save your draft"
msgstr "Увійдіть або зареєструйтесь, щоб зберегти свою чернетку"

#: pretalx/cfp/templates/cfp/event/submission_user.html
msgid ""
"Organisers will not be able to see your draft or your email address. They "
"will be able to send you reminders about your pending proposal draft closer "
"to the deadline."
msgstr ""
"Організатори не зможуть бачити ваш проєкт або вашу електронну адресу. Вони "
"зможуть надсилати вам нагадування про ваш незавершений проєкт ближче до "
"дедлайну."

#: pretalx/cfp/templates/cfp/event/user_mails.html
msgid "Your Emails"
msgstr "Ваші електронні адреси"

#: pretalx/cfp/templates/cfp/event/user_mails.html
msgid ""
"These are emails the organisers sent you, so you should be able to find them "
"in your email inbox, but this page serves as a helper in case your email "
"address was unavailable or the emails got lost in some way."
msgstr ""
"Це електронні листи, які надіслали вам організатори, тому ви повинні знайти "
"їх у своїй поштовій скриньці. Проте ця сторінка слугує допоміжним "
"інструментом на випадок, якщо ваша електронна адреса була недоступна або "
"листи загубилися."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Your Profile"
msgstr "Ваш профіль"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid ""
"This data will be displayed publicly if your proposal is accepted. It is "
"also visible to reviewers."
msgstr ""
"Ці дані будуть публічно показані, якщо вашу пропозицію приймуть. Вони також "
"видимі для рецензентів."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "We have some questions"
msgstr "У нас є кілька запитань"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Your Account"
msgstr "Ваш акаунт"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "You can change your login data here."
msgstr "Тут ви можете змінити свої дані для входу."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Account deletion"
msgstr "Видалення акаунта"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid ""
"You can delete your account here – all names, emails, and other personal "
"information will be overwritten. <strong>This action is irreversible.</"
"strong>"
msgstr ""
"Ви можете видалити свій акаунт тут – всі імена, електронні адреси та інша "
"особиста інформація буде перезаписана. <strong>Цю дію неможливо скасувати.</"
"strong>"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid ""
"I really do want to delete my account, losing access to my proposals and "
"sessions, and overriding my public and private data."
msgstr ""
"Я дійсно хочу видалити свій акаунт, втратити доступ до своїх пропозицій і "
"сесій та перезаписати мої публічні та приватні дані."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Delete my account"
msgstr "Видалити мій акаунт"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm.html
msgid "Congratulations on your acceptance!"
msgstr "Вітаємо з прийняттям вашої пропозиції!"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm.html
msgid ""
"By confirming your proposal, you agree that you are able and willing to "
"participate in this event and present the content of this proposal. The "
"proposal data, such as title, abstract, description, and any uploads you "
"provided, can be made publicly available once the proposal is confirmed."
msgstr ""
"Підтверджуючи свою пропозицію, ви погоджуєтеся, що маєте змогу та бажання "
"брати участь у цьому заході та презентувати зміст цієї пропозиції. Дані "
"пропозиції, такі як назва, анотація, опис та будь-які надані файли, можуть "
"стати публічно доступними після підтвердження пропозиції."

#: pretalx/cfp/templates/cfp/event/user_submission_confirm.html
msgid ""
"Please provide us with your available hours during the event, so that we can "
"schedule your session accordingly:"
msgstr ""
"Будь ласка, вкажіть години коли ви доступні під час заходу, щоб ми могли "
"відповідно спланувати вашу сесію:"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm_error.html
msgid "Proposal not found"
msgstr "Пропозицію не знайдено"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm_error.html
msgid ""
"The proposal you’re trying to confirm either does not exist or does not "
"belong to the account you’re currently logged in with. Try logging in with a "
"different account, or contact the event organisers for further information."
msgstr ""
"Пропозиція, яку ви намагаєтесь підтвердити, або не існує, або не належить "
"акаунту, під яким ви зараз увійшли. Спробуйте увійти під іншим акаунтом або "
"зверніться до організаторів заходу для отримання додаткової інформації."

#: pretalx/cfp/templates/cfp/event/user_submission_discard.html
msgid ""
"Do you really want to discard your draft proposal? All data will be lost."
msgstr ""
"Ви справді хочете відкинути свою чернетку пропозиції? Всі дані будуть "
"втрачені."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Confirm your attendance"
msgstr "Підтвердити вашу участь"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/orga/templates/orga/submission/feedback_list.html
#: pretalx/orga/templates/orga/submission/feedbacks_list.html
msgid "Attendee feedback"
msgstr "Відгуки учасників"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Attendees can leave feedback here after your session has taken place."
msgstr "Учасники можуть залишити відгуки тут після завершення вашої сесії."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Save draft"
msgstr "Зберегти чернетку"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Share proposal"
msgstr "Поділитися пропозицією"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"If you need a review from a colleague or a friend here’s a link that you can "
"send out for viewing your proposal:"
msgstr ""
"Якщо вам потрібен відгук від колеги або друга, ось посилання, яке ви можете "
"надіслати для перегляду вашої пропозиції:"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/cfp/templates/cfp/event/user_submission_withdraw.html
msgid "Withdraw proposal"
msgstr "Відкликати пропозицію"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"You can withdraw your proposal from the selection process here. You cannot "
"undo this - if you are just uncertain if you can or should hold your "
"session, please contact the organiser instead."
msgstr ""
"Тут ви можете відкликати свою пропозицію з процесу відбору. Цю дію не можна "
"скасувати — якщо ви просто не впевнені, чи зможете провести сесію або чи "
"слід її проводити, будь ласка, зв’яжіться з організатором."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/cfp/templates/cfp/event/user_submission_withdraw.html
#: pretalx/cfp/views/user.py
msgid "Withdraw"
msgstr "Відкликати"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Discard draft proposal"
msgstr "Відкинути чернетку пропозиції"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"You can discard your draft proposal here. You cannot undo this - if you are "
"just uncertain if you can or should submit your proposal, please contact the "
"organiser instead."
