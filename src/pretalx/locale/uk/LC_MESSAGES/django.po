#: pretalx/orga/forms/export.py
msgid "Picture"
msgstr "Зображення"

#: pretalx/orga/forms/export.py
msgid "The link to the speaker’s profile picture"
msgstr "Посилання на фотографію профілю доповідача"

#: pretalx/orga/forms/review.py
