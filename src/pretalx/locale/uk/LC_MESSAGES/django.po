msgstr ""
"Унікальний ID доповідача використовується в URL доповідача та при експорті"

#: pretalx/orga/forms/export.py
msgid "Speaker names"
msgstr "Імена доповідачів"

#: pretalx/orga/forms/export.py
msgctxt "date as in calendar date"
msgid "date"
msgstr "дата"

#: pretalx/orga/forms/export.py
msgid "time"
msgstr "час"

#: pretalx/orga/forms/export.py
msgid "Median score"
msgstr "Медіанна оцінка"

#: pretalx/orga/forms/export.py
msgid "Median review score, if there have been reviews yet"
msgstr "Медіанна оцінка рецензії, якщо рецензії вже були"

#: pretalx/orga/forms/export.py
msgid "Average (mean) score"
