msgid "Visibility"
msgstr "Видимість"

#: pretalx/orga/forms/cfp.py pretalx/orga/templates/orga/cfp/editor.html
msgid "Required"
msgstr "Необхідно"

#: pretalx/orga/forms/cfp.py pretalx/submission/models/question.py
msgid "Minimum length"
msgstr "Мінімальна довжина"

#: pretalx/orga/forms/cfp.py pretalx/submission/models/question.py
msgid "Maximum length"
