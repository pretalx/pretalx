#: pretalx/orga/forms/export.py
msgid "Average review score, if there have been reviews yet"
msgstr "Середня оцінка рецензії, якщо рецензії вже були"

#: pretalx/orga/forms/export.py
msgid "Resources provided by the speaker, either as links or as uploaded files"
msgstr ""
"Ресурси, надані доповідачем, у вигляді посилань або завантажених файлів"

#: pretalx/orga/forms/export.py pretalx/orga/tables/submission.py
#, fuzzy
#| msgid "Number of reviews"
msgid "Number of attendees"
msgstr "Кількість оцінок"

#: pretalx/orga/forms/export.py
