#: pretalx/orga/forms/cfp.py
msgid "Minimum tags"
msgstr "Мінімум тегів"

#: pretalx/orga/forms/cfp.py
msgid "Maximum tags"
msgstr "Максимум тегів"

#: pretalx/orga/forms/cfp.py
msgid ""
"Additional instructions shown below the field. Note: Only public tags will "
"be shown to submitters."
msgstr ""
"Додаткові інструкції під полем. Лише публічні теги видимі для учасників."

#: pretalx/orga/forms/cfp.py
msgid "Minimum tags cannot be greater than maximum tags."
msgstr ""
"Мінімальна кількість тегів не може перевищувати максимальну кількість тегів."

#: pretalx/orga/forms/cfp.py
msgid "Step title"
msgstr "Назва кроку"

#: pretalx/orga/forms/cfp.py
msgid "Leave empty to use the default title."
msgstr "Залиште порожнім, щоб використати назву за замовчуванням."

#: pretalx/orga/forms/cfp.py
msgid "Step description"
msgstr "Опис кроку"

#: pretalx/orga/forms/cfp.py
msgid "Leave empty to use the default description."
msgstr "Залиште порожнім, щоб використати опис за замовчуванням."

#: pretalx/orga/forms/export.py
msgid "Export format"
msgstr "Формат експорту"

#: pretalx/orga/forms/export.py
msgid "A CSV export can be opened directly in Excel and similar applications."
msgstr ""
"CSV експорт можна відкрити безпосередньо в Excel та подібних програмах."

#: pretalx/orga/forms/export.py
msgid "CSV export"
msgstr "Експорт у CSV"

#: pretalx/orga/forms/export.py
