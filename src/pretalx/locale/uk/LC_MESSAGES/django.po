msgstr "Призначити пропозиції рецензентам"

#: pretalx/orga/forms/review.py
msgid "Assign reviewers to proposals"
msgstr "Призначити рецензентів пропозиціям"

#: pretalx/orga/forms/review.py
msgid "Add tags"
msgstr "Додати теги"

#: pretalx/orga/forms/review.py
msgid "Remove tags"
