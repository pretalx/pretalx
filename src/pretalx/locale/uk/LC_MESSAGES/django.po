msgstr "Тільки доповідачі з прийнятими та підтвердженими пропозиціями"

#: pretalx/orga/forms/export.py
msgid "Proposal IDs"
msgstr "ID пропозицій"

#: pretalx/orga/forms/export.py
msgid "Proposal titles"
