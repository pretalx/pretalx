"Wystąpił błąd podczas logowania. Prosimy o kontakt z organizatorem w celu "
"uzyskania dalszej pomocy."

#: pretalx/cfp/flow/steps.py:375
msgid "Account"
msgstr "Konto"

#: pretalx/cfp/flow/steps.py:380
