#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid "Your proposal: {submission_title}"
msgstr "Twoje zgłoszenie: {submission_title}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We have received your proposal “{submission_title}” to\n"
"{event_name}. We will notify you once we have had time to consider all\n"
"proposals, but until then you can see and edit your proposal at\n"
"{submission_url}.\n"
"\n"
"Please do not hesitate to contact us if you have any questions!\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Cześć!\n"
"\n"
"Otrzymaliśmy twoje zgłoszenie „{submission_title}” na {event_name}. \n"
"Powiadomimy cię, gdy przeanalizujemy wszystkie zgłoszenia, ale do tego "
"czasu \n"
"możesz zobaczyć i edytować swoją propozycję pod adresem \n"
"{submission_url}.\n"
"\n"
"Zachęcamy do kontaktu, jeśli masz jakiekolwiek pytania!\n"
"\n"
"Organizatorzy {event_name}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We are happy to tell you that we accept your proposal “{submission_title}”\n"
"to {event_name}. Please click this link to confirm your attendance:\n"
"\n"
"{confirmation_link}\n"
"\n"
"We look forward to seeing you at {event_name} - Please contact us if you "
"have any\n"
"questions! We will reach out again before the conference to tell you "
"details\n"
"about your slot in the schedule and technical details concerning the room\n"
"and presentation tech.\n"
"\n"
"See you there!\n"
"The {event_name} organisers"
msgstr ""
"Cześć!\n"
"\n"
"Z dumą chcielibyśmy oznajmić Ci, że Twoje zgłoszenie „{submission_title}”\n"
"do wydarzenia {event_name} zostało zaakceptowane. Kliknij tutaj, aby "
"potwierdzić swoją obecność.\n"
"\n"
"{confirmation_link}\n"
"\n"
"Czekamy na Ciebie na wydarzeniu {event_name} - Skontaktuj się z nami, jeśli "
"będziesz mieć jakieś pytania.\n"
"Napiszemy do Ciebie przed wydarzeniem, aby przekazać wszystkie \n"
"szczegóły dotyczące zarówno harmonogramu jak i technikaliów \n"
"i szczegółów odnośnie prezentacji.\n"
"\n"
"Do zobaczenia!\n"
