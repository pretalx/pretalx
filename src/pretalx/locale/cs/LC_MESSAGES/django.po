msgid ""
"If you check this, the emails will be sent immediately, instead of being put "
"in the outbox."
msgstr ""
"Pokud toto vyberete, nebudou e-maily umístěné do fronty k odeslání, ale "
"budou odeslané hned."

#: pretalx/mail/interfaces/forms/compose.py
msgid "Recipient groups"
msgstr "Skupiny příjemců"

#: pretalx/mail/interfaces/forms/compose.py
msgid "Reviewers"
msgstr "Kontrolující"

#: pretalx/mail/interfaces/forms/compose.py
msgid "Other teams"
msgstr "Ostatní týmy"

#: pretalx/mail/interfaces/forms/compose.py
msgid ""
"Select proposals that should receive the email regardless of the other "
