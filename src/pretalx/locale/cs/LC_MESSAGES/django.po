msgstr ""
"Vyberte přihlášky, jejichž odesilatelé mají obdržet e-mail bez ohledu na "
"ostatní filtry."

#: pretalx/mail/interfaces/forms/compose.py
msgid ""
"Select speakers that should receive the email regardless of the other "
"filters."
msgstr ""
"Vyberte přednášející, kteří mají obdržet e-mail bez ohledu na ostatní filtry."

#: pretalx/mail/interfaces/forms/compose.py
msgid ""
"If you provide only one language, that language will be used for all emails. "
"If you provide multiple languages, the best fit for each speaker will be "
"used."
msgstr ""
"Pokud uvedete jenom jeden jazyk, bude použit pro všechny e-maily. Pokud "
"uvedete více jazyků, bude pro každého přednášejícího bude použit ten "
"nejvhodnější."

#: pretalx/mail/interfaces/forms/compose.py
msgid ""
"Please select at least one filter or specific proposals/speakers as "
"recipients."
msgstr ""

#: pretalx/mail/interfaces/forms/config.py
msgid "Contact address"
msgstr "Kontaktní adresa"

#: pretalx/mail/interfaces/forms/config.py
msgid ""
"Reply-To address. If this setting is empty and you have no custom sender, "
"your event email address will be used as Reply-To address."
msgstr ""
"Adresa pro odpověď. Pokud je toto nastavení prázdné a nezadáte vlastního "
"odesílatele, bude jako adresa pro odpověď použita e-mailová adresa události."

#: pretalx/mail/interfaces/forms/config.py
msgid "Email subject prefix"
msgstr "Prefix předmětu e-mailu"

#: pretalx/mail/interfaces/forms/config.py
msgid "The prefix will be prepended to outgoing email subjects in [brackets]."
msgstr ""
"Prefix bude přidán na začátek předmětu odchozích e-mailových zpráv v "
"[závorkách]."

#: pretalx/mail/interfaces/forms/config.py
msgid "Email signature"
msgstr "Podpis e-mailu"

#: pretalx/mail/interfaces/forms/config.py
msgid "The signature will be added to outgoing emails, preceded by “-- ”."
msgstr "Podpis bude přidán do odchozích e-mailů, předcházené znaky “-- ”."

#: pretalx/mail/interfaces/forms/config.py
msgid "Use custom SMTP server"
msgstr "Použít vlastní SMTP server"

#: pretalx/mail/interfaces/forms/config.py
msgid ""
"All email related to your event will be sent over the SMTP server specified "
"by you."
msgstr ""
"Všechny e-maily týkající se vaší události budou odesílány pomocí vámi "
"zvoleného SMTP serveru."

#: pretalx/mail/interfaces/forms/config.py
msgid "Sender address"
msgstr "Adresa odesílatele"

#: pretalx/mail/interfaces/forms/config.py
msgid "Sender address for outgoing emails."
msgstr "Adresa odesílatele odchozí pošty."

#: pretalx/mail/interfaces/forms/config.py
msgid "Hostname"
msgstr "Hostname"

#: pretalx/mail/interfaces/forms/config.py
#: pretalx/orga/templates/orga/admin/admin.html
msgid "Port"
msgstr "Port"

#: pretalx/mail/interfaces/forms/config.py
msgid "Username"
msgstr "Uživatelské jméno"

#: pretalx/mail/interfaces/forms/config.py
#: pretalx/orga/templates/orga/admin/admin.html
#: pretalx/orga/templates/orga/cfp/editor.html
#: pretalx/person/interfaces/forms/auth.py
msgid "Password"
msgstr "Heslo"

#: pretalx/mail/interfaces/forms/config.py
#, python-brace-format
msgid ""
"The password contains unsupported letters. Please only use characters A-Z, a-"
"z, 0-9, and common special characters ({characters})."
msgstr ""
"Heslo obsahuje nepodporované znaky. Použijte prosím jen A-Z, a-z, 0-9 nebo "
"běžné speciální znaky ({characters})."

#: pretalx/mail/interfaces/forms/config.py
msgid "Use STARTTLS"
msgstr "Použít STARTTLS"

#: pretalx/mail/interfaces/forms/config.py
msgid "Commonly enabled on port 587."
msgstr "Obvykle dostupné na portu 587."

#: pretalx/mail/interfaces/forms/config.py
msgid "Use SSL"
msgstr "Použít SSL"

#: pretalx/mail/interfaces/forms/config.py
msgid "Commonly enabled on port 465."
msgstr "Obvykle dostupné na portu 465."

#: pretalx/mail/interfaces/forms/config.py
msgid "You have to provide a sender address if you use a custom SMTP server."
msgstr "Při použití vlastního SMTP serveru je nutné zadat adresu odesílatele."

#: pretalx/mail/interfaces/forms/config.py
msgid ""
"You can activate either SSL or STARTTLS security, but not both at the same "
"time."
msgstr ""
"Můžete vybrat zabezpečení pomocí SSL nebo STARTTLS, ale ne obojí zároveň."

#: pretalx/mail/interfaces/forms/config.py
msgid ""
"You have to activate either SSL or STARTTLS security if you use a non-local "
"mailserver due to data protection reasons. Your administrator can add an "
"instance-wide bypass. If you use this bypass, please also adjust your "
"Privacy Policy."
msgstr ""
"Pokud nepoužíváte místní poštovní server, z důvodu ochrany dat musíte "
"aktivovat zabezpečení buď pomocí SSL nebo STARTTLS. Váš správce může přidat "
"výjimku na úrovni celé instance. V takovém případě také prosím upravte "
"Zásady ochrany osobních údajů."

#: pretalx/mail/interfaces/forms/queued_mail.py
msgid "An email needs to have at least one recipient."
msgstr "E-mail musí mít alespoň jednoho příjemce."

#: pretalx/mail/interfaces/forms/queued_mail.py pretalx/orga/tables/mail.py
msgctxt "email delivery status"
msgid "Status"
msgstr "Stav"

#: pretalx/mail/interfaces/forms/queued_mail.py
msgctxt "email status: not yet sent"
msgid "Pending"
msgstr "čekající"

#: pretalx/mail/interfaces/forms/queued_mail.py
#: pretalx/orga/templates/orga/mails/includes/mail_status_badge.html
msgctxt "email status"
msgid "Failed"
msgstr "Chyba"

#: pretalx/mail/models/queued_mail.py pretalx/orga/tables/mail.py
#: pretalx/submission/interfaces/forms/access_code.py
msgid "To"
msgstr "Komu"

#: pretalx/mail/models/queued_mail.py
msgid "One email address or several addresses separated by commas."
msgstr "Jedna e-mailová adresa, nebo několik adres oddělených čárkami."

#: pretalx/mail/models/queued_mail.py pretalx/mail/models/templates.py
msgid "Reply-To"
msgstr "Adresa pro odpověď"

#: pretalx/mail/models/queued_mail.py
msgid "By default, the organiser address is used as Reply-To."
msgstr ""
"Ve výchozím stavu je jako adresa pro odpověď použita adresa organizátora."

#: pretalx/mail/models/queued_mail.py
msgid "CC"
msgstr "Kopie"

#: pretalx/mail/models/queued_mail.py pretalx/mail/models/templates.py
msgid "BCC"
msgstr "Skrytá kopie"

#: pretalx/mail/models/queued_mail.py
msgid "Sent at"
msgstr "Odesláno"

#: pretalx/mail/models/templates.py
msgid ""
"Change the Reply-To address if you do not want to use the default organiser "
"address"
msgstr ""
"Pokud nechcete používat výchozí adresu organizátorů, změňte adresu pro "
"odpověď"

#: pretalx/mail/models/templates.py
msgid ""
"Enter comma separated addresses. Will receive a blind copy of every email "
"sent from this template. This may be a LOT!"
msgstr ""
"Zadejte adresy oddělené čárkami. Obdržíte slepou kopii každého e-mailu "
"odeslaného z této šablony. Může jich být opravdu hodně."

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid "Your proposal: {submission_title}"
msgstr "Vaše přihláška: {submission_title}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We have received your proposal “{submission_title}” to\n"
"{event_name}. We will notify you once we have had time to consider all\n"
"proposals, but until then you can see and edit your proposal at\n"
"{submission_url}.\n"
"\n"
"Please do not hesitate to contact us if you have any questions!\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"Obdrželi jsme vaši přihlášku „{submission_title}“ na událost\n"
"{event_name}. Po kontrole všech přihlášek vám dáme vědět, jestli\n"
"jsme ji přijali. Do té doby můžete přihlášku upravovat\n"
"na stránce {submission_url}.\n"
"\n"
"Pokud máte nějakou otázku, neváhejte nás kontaktovat.\n"
"\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We are happy to tell you that we accept your proposal “{submission_title}”\n"
"to {event_name}. Please click this link to confirm your attendance:\n"
"\n"
"{confirmation_link}\n"
"\n"
"We look forward to seeing you at {event_name} - Please contact us if you "
"have any\n"
"questions! We will reach out again before the conference to tell you "
"details\n"
"about your slot in the schedule and technical details concerning the room\n"
"and presentation tech.\n"
"\n"
"See you there!\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"S radostí vám oznamujeme, že jsme přijali vaši přihlášku "
"„{submission_title}“\n"
"na událost {event_name}. Pro potvrzení své účasti klepněte na tento odkaz:\n"
"\n"
"{confirmation_link}\n"
"\n"
"Těšíme se na vás během události {event_name}. Kontaktujte nás, pokud máte\n"
"jakékoliv dotazy. Před konferencí se vám znovu ozveme s podrobnostmi\n"
"o zařazení vaší přednášky do programu a podrobnostmi o místnosti\n"
"a prezentační technice.\n"
"\n"
"Na viděnou.\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We are sorry to tell you that we cannot accept your proposal\n"
"“{submission_title}” to {event_name}. There were just too many great\n"
"proposals - we hope to see you at {event_name} as an attendee instead\n"
"of a speaker!\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"Je nám líto, ale vaši přihlášku „{submission_title}“ na událost "
"{event_name}\n"
"jsme nemohli přijmout. Přednášek bylo prostě přihlášených příliš mnoho.\n"
"Doufáme, že na {event_name} přijdete alespoň jako návštěvník.\n"
"\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
msgid "New schedule!"
msgstr "Nový program!"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We have released a new schedule version, and wanted to tell you:\n"
"\n"
"{speaker_schedule_new}\n"
"\n"
"We look forward to seeing you, and please contact us if there is any problem "
"with your session or assigned slot.\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"Zveřejnili jsme novou verzi programu a chceme vám o ní říct:\n"
"\n"
"{speaker_schedule_new}\n"
"\n"
"Těšíme se na vás. Neváhejte nás kontaktovat, pokud budete mít se zařazením "
"přednášky do programu jakýkoliv problém.\n"
"\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
msgid "We have some questions about your proposal"
msgstr "Máme pár otázek k vaší přihlášce"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"We have some open questions about yourself and your proposal that we’d\n"
"like to ask you to answer:\n"
"\n"
"{questions}\n"
"\n"
"You can answer them at {url}.\n"
"\n"
"Please do not hesitate to contact us if you have any questions in turn!\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"Máme na vás pár otázek o vás nebo vaší přihlášce, na které bychom rádi "
"znali\n"
"odpověď:\n"
"\n"
"{questions}\n"
"\n"
"Odpovědět na ně můžete na adrese {url}.\n"
"\n"
"Neváhejte se nás kontaktovat, pokud máte naopak nějakou otázku na nás.\n"
"\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid "New proposal: {proposal_title}"
msgstr "Nová přihláška: {proposal_title}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi,\n"
"\n"
"you have received a new proposal for your event {event_name}:\n"
"“{submission_title}” by {speakers}.\n"
"You can see details at\n"
"\n"
"  {orga_url}\n"
"\n"
"All the best,\n"
"your {event_name} CfP system.\n"
msgstr ""
"Zdravíme.\n"
"\n"
"Obdrželi jste novou přihlášku na událost {event_name}:\n"
"„{submission_title}“ od {speakers}.\n"
"Podrobnosti najdete na\n"
"\n"
"  {orga_url}\n"
"\n"
"S pozdravem\n"
"váš CfP systém pro {event_name}.\n"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid "You have been added to a proposal for {event_name}"
msgstr "Byli jste přidání do přihlášky na událost {event_name}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"You have been added to a proposal of {event_name}, titled "
"“{proposal_title}”.\n"
"An account has been created for you – please follow this link to set your "
"account password.\n"
"\n"
"{invitation_link}\n"
"\n"
"Afterwards, you can edit your user profile and see the state of your "
"proposal.\n"
"\n"
"The {event} orga crew"
msgstr ""
"Zdravíme.\n"
"\n"
"Byli jste přidáni do přihlášky na událost {event_name} s názvem "
"„{proposal_title}“.\n"
"Vytvořili jsme proto pro vás účet – navštivte prosím tento odkaz pro "
"nastavení hesla.\n"
"\n"
"{invitation_link}\n"
"\n"
"Po nastavení hesla si bude moci upravit uživatelský profil a zobrazit stav "
"své přihlášky.\n"
"\n"
"Organizátoři {event}"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"You have been added to a proposal of {event_name}, titled "
"“{proposal_title}”.\n"
"Please follow this link to edit your user profile and see the state of your "
"proposal:\n"
"\n"
"{proposal_url}\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"Byli jste přidáni do přihlášky na událost {event_name} s názvem "
"„{proposal_title}“.\n"
"Navštivte prosím tento odkaz pro úpravu uživatelského profilu a zobrazení "
"stavu přihlášky:\n"
"\n"
"{proposal_url}\n"
"\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
msgid "Reminder: Submit your proposal"
msgstr "Připomínka: Odešlete svou přihlášku"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"You have started a proposal \"{submission_title}\" for {event_name},\n"
"but you haven't submitted it yet. Please go to\n"
"\n"
"{submission_url}\n"
"\n"
"to complete and submit your proposal.\n"
"\n"
"Please do not hesitate to contact us if you have any questions!\n"
"\n"
"The {event_name} organisers"
msgstr ""
"Zdravíme.\n"
"\n"
"Rozpracovali jste přihlášku „{submission_title}“ na událost {event_name},\n"
"ale zatím jste ji neodeslali. Pro dokončení a odeslání přihlášky navštivte\n"
"\n"
"{submission_url}\n"
"\n"
"Pokud máte nějakou otázku, neváhejte nás kontaktovat.\n"
"\n"
"Organizátoři {event_name}"

#: pretalx/mail/template_phrases.py
msgid "Password recovery"
msgstr "Obnova hesla"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi {name},\n"
"\n"
"you have requested a new password for your pretalx account.\n"
"To reset your password, click on the following link:\n"
"\n"
"  {url}\n"
"\n"
"If this wasn’t you, you can just ignore this email.\n"
"\n"
"All the best,\n"
"the pretalx robot"
msgstr ""
"Zdravíme, {name}.\n"
"\n"
"Zažádali jste o obnovení hesla pro svůj účet pretalx.\n"
"Pro obnovení hesla klepněte na následující odkaz:\n"
"\n"
"  {url}\n"
"\n"
"Pokud jste o obnovení nežádali, považujte tento e-mail za bezpředmětný.\n"
"\n"
"S pozdravem\n"
"Pretalx robot"

#: pretalx/mail/template_phrases.py
msgid "[pretalx] Password changed"
msgstr "[pretalx] Heslo změněno"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi {name},\n"
"\n"
"Your pretalx account password was just changed.\n"
"\n"
"If you did not change your password, please contact the site administration "
"immediately.\n"
"\n"
"All the best,\n"
"the pretalx team"
msgstr ""
"Zdravíme {name}.\n"
"\n"
"Heslo vašeho pretalx účtu bylo změněno.\n"
"\n"
"Pokud jste své heslo neměnili, kontaktujte prosím bez prodlení správce.\n"
"\n"
"S pozdravem,\n"
"tým pretalxu"

#: pretalx/mail/template_phrases.py
msgid "[pretalx] Email address changed"
msgstr "[pretalx] E-mailová adresa změněna"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi {name},\n"
"\n"
"This is a confirmation that the email address for your pretalx account has "
"been changed from {old_email} to {new_email}.\n"
"\n"
"If you did not perform this change, please contact an administrator "
"immediately.\n"
"\n"
"All the best,\n"
"the pretalx team"
msgstr ""
"Zdravíme {name}.\n"
"\n"
"Potvrzujeme, že e-mailová adresa vašeho pretalx účtu byla změněna z "
"{old_email} na {new_email}.\n"
"\n"
"Pokud jste tuto změnu neprovedli, kontaktujte prosím bez prodlení správce.\n"
"\n"
"S pozdravem,\n"
"tým pretalxu"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi,\n"
"\n"
"just writing you to let you know that your Call for Proposals is now\n"
"closed. Here is a list of links that should be useful in the next days:\n"
"\n"
"- You’ll find a list of all your {submission_count} proposals here:\n"
"  {event_submissions}\n"
"- You can add reviewers here:\n"
"  {event_team}\n"
"- You can review proposals here:\n"
"  {event_review}\n"
"- And create your schedule here, once you have accepted proposals:\n"
"  {event_schedule}\n"
msgstr ""
"Zdravíme.\n"
"\n"
"Jenom píšeme, že jsme uzavřeli Call for Participation.\n"
"Tady je seznam odkazů, které se vám v následujících dnech budou hodit:\n"
"\n"
"- Seznam všech {submission_count} přihlášek:\n"
"  {event_submissions}\n"
"- Tady můžete přiřadit přihlášky ke kontrole:\n"
"  {event_team}\n"
"- Přihlášky můžete začít kontrolovat tady:\n"
"  {event_review}\n"
"- A nakonec tady můžete po přijetí přihlášek vytvořit program události:\n"
"  {event_schedule}\n"

#: pretalx/mail/template_phrases.py
#, python-brace-format
msgid ""
"Hi,\n"
"\n"
"congratulations, your event is over! Hopefully it went well. Here are some\n"
"statistics you might find interesting:\n"
"\n"
"- You had {submission_count} proposals,\n"
"- Of which you selected {talk_count} sessions.\n"
"- The reviewers wrote {review_count} reviews.\n"
"- You released {schedule_count} schedules in total.\n"
"- Over the course of the event, you sent {mail_count} emails.\n"
"\n"
"If there is anything you’re missing, come tell us about it\n"
"at https://github.com/pretalx/pretalx/issues/new or via an\n"
"email to support@pretalx.com!\n"
msgstr ""
"Zdravíme.\n"
"\n"
"Gratulujeme, vaše událost je za vámi! Určitě byla skvělá, a tady najdete\n"
"některé zajímavé statistiky:\n"
"\n"
"- Obdrželi jste {submission_count} přihlášek,\n"
"- Ze kterých jste vybrali {talk_count} přednášek.\n"
"- Během kontroly bylo napsáno {review_count} hodnocení.\n"
"- Zveřejnili jste celkem {schedule_count} verzí programu.\n"
"- Během události jste rozeslali celkem {mail_count} e-mailů.\n"
"\n"
"Pokud vám cokoliv chybí, dejte nám o tom prosím vědět\n"
"na adrese https://github.com/pretalx/pretalx/issues/new nebo\n"
"e-mailem na support@pretalx.com.\n"

#: pretalx/mail/validators.py
msgid ""
"Invalid email template! Please check that you don’t have stray { or } "
"somewhere, and that there are no spaces inside the {} blocks."
msgstr ""
"Šablona e-mailu není platná. Zkontrolujte prosím, jestli někde nemáte "
"zbloudilé { or }, a že uvnitř bloků {} nejsou žádné mezery."

#: pretalx/mail/validators.py
msgid "Unknown placeholder!"
msgstr "Neznámý zástupný symbol!"

#: pretalx/mail/validators.py
#, python-brace-format
msgid "You have an empty link in your email, labeled “{text}”!"
msgstr "Ve svém e-mailu máte prázdný odkaz označený jako „{text}“!"

#: pretalx/orga/forms/admin.py
msgid "Perform update checks"
msgstr "Zkontrolovat aktualizace"

#: pretalx/orga/forms/admin.py
msgid ""
"During the update check, pretalx will report an anonymous, unique "
"installation ID, the current version of pretalx and your installed plugins "
"and the number of active and inactive events in your installation to servers "
"operated by the pretalx developers. We will only store anonymous data, never "
"any IP addresses and we will not know who you are or where to find your "
"instance. You can disable this behavior here at any time."
msgstr ""
"Během kontroly aktualizací pretalx odešle na servery vývojářů anonymní ale "
"jedinečné ID instalace, svou současnou verzi, seznam nainstalovaných pluginů "
"a počet aktivních a neaktivních událostí ve vaší instanci. Ukládáme pouze "
"anonymní data, nikdy ne IP adresu, a tak nevíme, kdo jste ani kde vaši "
"instanci najít. Toto chování tady můžete také kdykoliv zakázat."

#: pretalx/orga/forms/admin.py
msgid "Email notifications"
msgstr "E-mailová oznámení"

#: pretalx/orga/forms/admin.py
msgid ""
"We will notify you at this address if we detect that a new update is "
"available. This address will not be transmitted to pretalx.com, the emails "
"will be sent by your server locally."
msgstr ""
"Na tuto adresa vás budeme informovat pokud zjistíme, že je dostupná nová "
"aktualizace. Tato adresa nebude odeslána na pretalx.com, e-maily bude "
"posílat váš vlastní server."

#: pretalx/orga/forms/cfp.py
msgid "Send email on new proposal"
msgstr "Posílat e-maily o nových přihláškách"

#: pretalx/orga/forms/cfp.py
msgid ""
"If this setting is checked, you will receive an email to the organiser "
"address for every received proposal."
msgstr ""
"Pokud je tato volba vybrána, dostanete e-mail na adresu organizátora "
"kdykoliv dostanete nějakou přihlášku."

#: pretalx/orga/forms/cfp.py
msgid "Allow submitters to share their proposal publicly"
msgstr "Povolit přihlášeným, aby sdíleli svou přihlášku veřejně"

#: pretalx/orga/forms/cfp.py
msgid "Allow submitters to share a secret link to their proposal with others."
msgstr ""
"Povolit přihlášeným, aby sdíleli tajný odkaz na svou přihlášku s ostatními."

#: pretalx/orga/forms/cfp.py
msgid "Allow speakers to edit their proposals and profiles"
msgstr "Povolit přednášejícím upravovat své přihlášky a profily"

#: pretalx/orga/forms/cfp.py
#: pretalx/orga/templates/orga/organiser/team/_form.html
#: pretalx/orga/templates/orga/settings/review.html
msgid "Review settings"
msgstr "Nastavení kontroly"

#: pretalx/orga/forms/cfp.py
#, python-brace-format
msgid ""
"If disabled, speakers cannot edit their proposals regardless of the proposal "
"state. This setting overrides the {review_phase_link} for speaker editing."
msgstr ""
"Pokud není povoleno, přednášející nebudou moci upravovat své přihlášky bez "
"ohledu na jejich stav. Toto nastavení má přednost před {review_phase_link} "
"pro úpravu přednášejících."

#: pretalx/orga/forms/cfp.py
msgid "Display deadline publicly"
msgstr "Zobrazit termín uzávěrky veřejně"

#: pretalx/orga/forms/cfp.py
msgid "Show the time and date the CfP ends to potential speakers."
msgstr "Zobrazovat potenciálním přednášejícím datum a čas termínu konce CfP."

#: pretalx/orga/forms/cfp.py
msgid "Count text length in"
msgstr "Počítat délku textu jako"

#: pretalx/orga/forms/cfp.py
msgid "Characters"
msgstr "znaky"

#: pretalx/orga/forms/cfp.py
msgid "Words"
msgstr "slova"

#: pretalx/orga/forms/cfp.py
msgid "Custom label"
msgstr "Vlastní označení"

#: pretalx/orga/forms/cfp.py
msgid "Leave empty to use the default label."
msgstr "Ponechte prázdné pro použití výchozího označení."

#: pretalx/orga/forms/cfp.py pretalx/orga/templates/orga/cfp/editor.html
#: pretalx/submission/models/question.py
msgid "Help text"
msgstr "Text nápovědy"

#: pretalx/orga/forms/cfp.py
msgid "Additional instructions shown below the field."
msgstr ""

#: pretalx/orga/forms/cfp.py
msgid "Visibility"
msgstr "Viditelnost"

#: pretalx/orga/forms/cfp.py pretalx/orga/templates/orga/cfp/editor.html
msgid "Required"
msgstr "Vyžadováno"

#: pretalx/orga/forms/cfp.py pretalx/submission/models/question.py
msgid "Minimum length"
msgstr "Minimální délka"

#: pretalx/orga/forms/cfp.py pretalx/submission/models/question.py
msgid "Maximum length"
msgstr "Maximální délka"

