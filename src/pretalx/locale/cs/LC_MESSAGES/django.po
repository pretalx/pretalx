msgstr "Bude použito jako adresa pro odpověď na e-maily."

#: pretalx/event/models/event.py
msgid "Custom domain"
msgstr "Vlastní doména"

#: pretalx/event/models/event.py
msgid "Enter a custom domain, such as https://my.event.example.org"
msgstr "Zadejte vlastní doménu, např. https://nase.udalost.example.org"

#: pretalx/event/models/event.py
msgid "Main event colour"
msgstr "Hlavní barva události"

#: pretalx/event/models/event.py
msgid ""
"Provide a hex value like #00ff00 if you want to style pretalx in your "
"event’s colour scheme."
msgstr ""
"Pokud chcete nastavit barvu vzhledu pretalxu podle své události, zadejte "
"hodnotu v hexadecimálním formátu (např. #00ff00)."

#: pretalx/event/models/event.py
msgid "Custom Event CSS"
msgstr "Vlastní CSS události"

#: pretalx/event/models/event.py
msgid ""
"Upload a custom CSS file if changing the primary colour is not sufficient "
"for you."
msgstr ""
"Nahrajte soubor s vlastními CSS styly, pokud pro vás není změna hlavní barvy "
"dostatečná."

#: pretalx/event/models/event.py
msgid "Logo"
msgstr "Logo"

#: pretalx/event/models/event.py
msgid ""
"If you provide a logo image, your event’s name will not be shown in the "
"event header. The logo will be scaled down to a height of 140px."
msgstr ""
"Pokud zadáte obrázek loga, název vaší události se v záhlaví nebude "
"zobrazovat. Logo bude zmenšeno na 150px na výšku."

#: pretalx/event/models/event.py
msgid "Header image"
msgstr "Obrázek záhlaví"

#: pretalx/event/models/event.py
msgid ""
"If you provide a header image, it will be displayed instead of your event’s "
"color and/or header pattern at the top of all event pages. It will be center-"
"aligned, so when the window shrinks, the center parts will continue to be "
"displayed, and not stretched."
msgstr ""
"Pokud zadáte obrázek záhlaví, zobrazí se místo barvy vaší události a/nebo "
"vzoru v záhlaví nahoře na stránkách události. Bude zarovnán na střed, takže "
"bude vidět i při zmenšení okna, a nebude nijak roztažený."

#: pretalx/event/models/event.py
msgid "Preview image"
msgstr "Náhled obrázku"

#: pretalx/event/models/event.py
msgid ""
"This image will be shown as a preview when links to your event are shared on "
"social media or messaging apps. For best results, use an image at least "
"1200x630 pixels. If not set, the logo or header image will be used instead."
msgstr ""

#: pretalx/event/models/event.py
msgid "Default language"
msgstr "Výchozí jazyk"

#: pretalx/event/models/event.py
msgid "Landing page text"
msgstr "Text výchozí stránky"

#: pretalx/event/models/event.py
msgid ""
"This text will be shown on the landing page, alongside with links to the CfP "
"and schedule, if appropriate."
msgstr ""
"Tento text se zobrazí na výchozí stránce společně s odkazy na CfP a program."

#: pretalx/event/models/event.py
msgid "Featured sessions text"
msgstr "Text vybraných přednášek"

#: pretalx/event/models/event.py
msgid ""
"This text will be shown at the top of the featured sessions page instead of "
"the default text."
msgstr ""
"Tento text se zobrazí nahoře na stránce s vybranými přednáškami místo "
"výchozího textu."

#: pretalx/event/models/event.py
msgid "Plain"
msgstr "Čistý"

#: pretalx/event/models/event.py
msgid "Circuits"
msgstr "Obvody"

#: pretalx/event/models/event.py
msgid "Circles"
msgstr "Kruhy"

#: pretalx/event/models/event.py
msgid "Signal"
msgstr "Signál"

#: pretalx/event/models/event.py
msgid "Topography"
msgstr "Topografie"

#: pretalx/event/models/event.py
msgid "Graph Paper"
msgstr "Milimetrový papír"

#: pretalx/event/models/event.py
msgid "Your default language needs to be one of your active languages."
msgstr "Váš výchozí jazyk musí být jedním z aktivních jazyků."

#: pretalx/event/models/event.py
msgid "Link text"
msgstr "Text odkazu"

#: pretalx/event/models/event.py
msgid "Link URL"
msgstr "URL odkazu"

#: pretalx/event/models/organiser.py
msgid ""
"Should be short, only contain lowercase letters and numbers, and must be "
"unique, as it is used in URLs."
msgstr ""
"Měla by být krátká, obsahovat jenom malá písmena a čísla, a musí být "
"jedinečná, protože se používá v URL adresách."

#: pretalx/event/models/organiser.py
msgid "Team name"
msgstr "Jméno týmu"

#: pretalx/event/models/organiser.py
msgid "Team members"
msgstr "Členové týmu"

#: pretalx/event/models/organiser.py
msgid ""
"Apply permissions to all events by this organiser (including newly created "
"ones)"
msgstr ""
"Použít oprávnění organizátora pro všechny události (včetně nově vytvářených)"

#: pretalx/event/models/organiser.py
msgid "Limit permissions to these events"
msgstr "Omezit oprávnění pro tyto události"

#: pretalx/event/models/organiser.py pretalx/person/models/information.py
#: pretalx/submission/models/review.py
msgid "Limit to tracks"
msgstr "Omezit pro dané tracky"

#: pretalx/event/models/organiser.py
msgid "Can create events"
msgstr "Může vytvářet události"

#: pretalx/event/models/organiser.py
msgid "Can change teams and permissions"
msgstr "Může měnit týmy a oprávnění"

#: pretalx/event/models/organiser.py
msgid "Can change organiser settings"
msgstr "Může měnit nastavení organizátorů"

#: pretalx/event/models/organiser.py
msgid "Can change event settings"
msgstr "Může měnit nastavení události"

#: pretalx/event/models/organiser.py
msgid "Can work with and change proposals"
msgstr "Může pracovat s a měnit přihlášky"

#: pretalx/event/models/organiser.py
msgid "Is a reviewer"
msgstr "Může kontrolovat přihlášky"

#: pretalx/event/models/organiser.py
msgid "Always hide speaker names"
msgstr "Vždy skrýt jméno přednášejícího"

#: pretalx/event/models/organiser.py
msgid ""
"Normally, anonymisation is configured in the event review settings. This "
"setting will <strong>override the event settings</strong> and always hide "
"speaker names for this team."
msgstr ""
"Obvykle je anonymizace nastavována v nastavení kontrol přednášek každé "
"události. Toto nastavení bude mít <strong>prioritu před nastavením události</"
"strong> a vždy pro tento tým skryje jména přednášejících."

#: pretalx/event/models/organiser.py
#, python-brace-format
msgid "{name} on {orga}"
msgstr "{name} na {orga}"

#: pretalx/event/models/organiser.py
#, python-brace-format
msgid "Invite to team {team} for {email}"
msgstr "Pozvánka do týmu {team} pro {email}"

#: pretalx/event/validators/event.py
msgid ""
"This short name is already taken, please choose another one (or ask the "
"owner of that event to add you to their team)."
msgstr ""
"Tento krátký název už je obsazený, vyberte prosím jiný (nebo požádejte "
"vlastníka původní události, aby vás přidal do svého týmu)."

#: pretalx/event/validators/event.py
msgid "Please do not choose the default domain as custom event domain."
msgstr "Nezadávejte prosím jako vlastní doménu výchozí doménu pretalxu."

#: pretalx/event/validators/event.py
#, python-brace-format
msgid ""
"The domain “{domain}” does not have a name server entry at this time. Please "
"make sure the domain is working before configuring it here."
msgstr ""
"Doména “{domain}” v tuto chvíli nemá záznam ve jmenných serverech. Před "
"provedením nastavení se ujistěte, že doména funguje."

#: pretalx/event/validators/organiser.py
msgid ""
"There must be at least one team with the permission to change teams, as "
"otherwise nobody can create new teams or grant permissions to existing teams."
msgstr ""
"Musí existovat nejméně jeden team s oprávněním pro změnu týmu, protože jinak "
"nebude moci vytvořit nové týmy nebo přidat oprávnění k existujícím týmům."

#: pretalx/event/validators/organiser.py
msgid "Nobody on your teams has the permission to create new events."
msgstr "Nikdo z vašich týmů nemá oprávnění vytvářet nové události."

#: pretalx/event/validators/organiser.py
msgid ""
"Nobody on your teams has the permission to change organiser-level settings."
msgstr ""
"Nikdo z vašich týmů nemá oprávnění změnit nastavení úrovně organizátor."

#: pretalx/event/validators/organiser.py
#, python-brace-format
msgid ""
"There must be at least one team with access to every event. Currently, "
"nobody has access to {event_name}."
msgstr ""
"Musí existovat nejméně jeden tým s přístupem ke každé události. Momentálně "
"nemá nikdo přístup k {event_name}."

#: pretalx/event/validators/organiser.py
#, python-brace-format
msgid ""
"Nobody on your teams has the permissions to change settings for the event "
"{event_name}"
msgstr ""
"Nikdo z vašich týmů nemá oprávnění změnit nastavení pro událost {event_name}"

#: pretalx/event/validators/team.py
msgid ""
"Please either pick some events, or grant access to all your events!"
msgstr ""
"Vyberte nějakou událost, nebo dejte oprávnění přístupu ke všem událostem!"

#: pretalx/event/validators/team.py
msgid "Please pick at least one permission for this team!"
msgstr "Vyberte pro tento tým alespoň jedno oprávnění."

