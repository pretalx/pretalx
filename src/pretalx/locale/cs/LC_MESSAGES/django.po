msgstr "Napsali jste {count} slov."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select exactly {count} tags."
msgstr "Vyberte přesně {count} štítků."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select between {min} and {max} tags."
msgstr "Vyberte mezi {min} a {max} tagy."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select at least {min} tags."
msgstr "Vyberte alespoň {min} tagy."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "Please select at most {max} tags."
msgstr "Vyberte maximálně {max} tagů."

#: pretalx/cfp/forms.py
#, python-brace-format
msgid "You selected {count} tags."
msgstr "Vybrali jste {count} tagů."

#: pretalx/cfp/phrases.py
msgid ""
"If we know a user by this email address (who has not requested a password "
"reset in the last 24 hours), we will send you an email containing further "
"instructions. If you don’t see the email within the next minutes, check your "
"spam inbox!"
msgstr ""
"Pokud máme v databázi uživatele s touto e-mailovou adresou (který nežádal o "
"obnovení hesla v posledních 24 hodinách), pošleme vám e-mail s dalšími "
"instrukcemi. Pokud vám e-mail nedorazí během několika minut, zkontrolujte "
"složky s nevyžádanou poštou a spamem."

#: pretalx/cfp/phrases.py
msgid ""
"This link was not valid. Make sure you copied the complete URL from the "
"email and that the email is no more than 24 hours old."
msgstr ""
"Tento odkaz není platný. Zkontrolujte, že jste zkopírovali celou adresu z e-"
"mailu a že tento e-mail nebyl starší než 24 hodin."

#: pretalx/cfp/phrases.py
msgid "Awesome! You can now log in using your new password."
msgstr "Skvělé! Nyní se můžete přihlásit pomocí svého nového hesla."

#: pretalx/cfp/phrases.py
msgid "Your proposal has been withdrawn."
msgstr "Vaše přihláška byla stažena."

#: pretalx/cfp/phrases.py
msgid ""
"Your proposal can’t be withdrawn at this time – please contact us if you "
"need to withdraw your proposal!"
msgstr ""
"Vaše přihláška nemůže být v tuto chvíli stažena - prosím kontaktujte nás, "
"pokud opravdu potřebujete stáhnout vaši přihlášku!"

#: pretalx/cfp/phrases.py
msgid "Your session has been confirmed – we’re looking forward to seeing you!"
msgstr "Vaše přednáška byla potvrzena – těšíme se na vás!"

#: pretalx/cfp/phrases.py
msgid ""
"This proposal has already been confirmed – we’re looking forward to seeing "
"you!"
msgstr "Tato přihláška byla již potvrzena – těšíme se na vás!"

#: pretalx/cfp/phrases.py
msgid ""
"This proposal cannot be confirmed at this time – please contact us if you "
"think this is an error."
msgstr ""
"Tato přihláška nemůže být v tuto chvíli potvrzena – prosím kontaktujte nás, "
"pokud si myslíte, že jde o chybu."

#: pretalx/cfp/phrases.py
msgid ""
"This proposal cannot be edited at this time. Please contact the organisers "
"if you need to make changes."
msgstr ""
"Tato přihláška nemůže být v tuto chvíli upravena – pro provedení změn prosím "
"kontaktujte organizátory."

#: pretalx/cfp/phrases.py
msgctxt "field: speaker's email address"
msgid "Speaker email"
msgstr "E-mail přednášejícího"

#: pretalx/cfp/phrases.py
#, python-brace-format
msgid "{inviting_speaker} invites you to join their session!"
msgstr "{inviting_speaker} Vás chce přidat do své přednášky!"

#: pretalx/cfp/phrases.py
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"I’d like to invite you to be a speaker in the session\n"
"\n"
"  “{proposal_title}”\n"
"\n"
"at {event_name}. Please follow this link to join:\n"
"\n"
"  {url}\n"
"\n"
"I’m looking forward to it!\n"
"{inviting_speaker}"
msgstr ""
"Zdravíme.\n"
"\n"
"Chci vás poprosit o odpřednášení přednášky\n"
"\n"
"  „{proposal_title}“\n"
"\n"
"na události {event_name}. Pro pokračování prosím klepněte na odkaz:\n"
"\n"
"  {url}\n"
"\n"
"Těšíme se.\n"
"{inviting_speaker}"

#: pretalx/cfp/phrases.py
msgid "Please provide a valid email address."
msgstr "Uveďte prosím platnou e-mailovou adresu."

#: pretalx/cfp/phrases.py pretalx/orga/views/organiser.py
msgid "The invitation has been sent."
msgstr "Pozvánka byla odeslána."

#: pretalx/cfp/phrases.py
msgid "You are now part of this proposal! Please fill in your profile below."
msgstr "Jste teď součástí této přihlášky! Prosím vyplňte váš profil níže."

#: pretalx/cfp/phrases.py
msgid ""
"We are experiencing difficulties when sending emails, but your session was "
"submitted successfully!"
msgstr ""
"Máme potíže s rozesíláním e-mailů, ale vaše přihláška byla úspěšně poslána!"

#: pretalx/cfp/phrases.py pretalx/common/log.py pretalx/orga/views/cfp.py
msgid "Custom fields"
msgstr "Vlastní pole"

#: pretalx/cfp/templates/cfp/event/cfp.html
#, python-format
msgid ""
"Submissions close on %(deadline)s (%(timezone)s), %(until_string)s from now."
msgstr ""
"Přidávání přihlášek bude uzavřeno %(deadline)s (%(timezone)s), "
"%(until_string)s od teď."

#: pretalx/cfp/templates/cfp/event/cfp.html
#, python-format
msgid "Submissions open on %(opening)s (%(timezone)s)."
msgstr "Přidávání přihlášek je otevřeno do %(opening)s (%(timezone)s)."

#: pretalx/cfp/templates/cfp/event/cfp.html
#, python-format
msgid "Submissions closed on %(deadline)s (%(timezone)s)."
msgstr "Přidávání přihlášek skončilo %(deadline)s (%(timezone)s)."

#: pretalx/cfp/templates/cfp/event/cfp.html
#: pretalx/cfp/templates/cfp/event/index.html
msgid "Submit a proposal"
msgstr "Odeslat přihlášku"

#: pretalx/cfp/templates/cfp/event/cfp.html pretalx/cfp/views/wizard.py
msgid "Proposals are closed"
msgstr "Přidávání přihlášek bylo uzavřeno"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/submission/enums.py
msgid "accepted"
msgstr "přijato"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/orga/views/dashboard.py pretalx/submission/enums.py
msgid "confirmed"
msgstr "potvrzeno"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/submission/enums.py
msgid "Cancelled"
msgstr "Zrušeno"

#: pretalx/cfp/templates/cfp/event/fragment_state.html pretalx/common/log.py
#: pretalx/submission/enums.py
msgid "withdrawn"
msgstr "staženo"

#: pretalx/cfp/templates/cfp/event/index.html
msgid "Go To Organiser Area"
msgstr "Přejít do rozhraní pro organizátory"

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid "Accept invitation?"
msgstr "Přijmout pozvánku?"

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid ""
"Unfortunately, you cannot accept this invitation at the moment. This may be "
"because the invitation has expired, or because the proposal cannot be edited "
"any more."
msgstr ""
"Bohužel tuto pozvánku nyní nemůžete přijmout. Je možné, že platnost pozvánka "
"vypršela, nebo už přihlášky nelze upravovat."

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid "Please contact the conference organisers for more information."
msgstr "Pro více informací kontaktujte organizátory konference."

#: pretalx/cfp/templates/cfp/event/invitation.html
#, python-format
msgid ""
"You, %(name)s, have been invited to be a speaker for the session “%(talk)s”. "
"Do you accept the invitation?"
msgstr ""
"%(name)s, byl jste pozván k spolupořádání přednášky \"%(talk)s\". Přijímáte "
"toto pozvání?"

#: pretalx/cfp/templates/cfp/event/invitation.html
#: pretalx/orga/templates/orga/submission/review.html
#: pretalx/submission/models/submission.py
msgid "Abstract"
msgstr "Abstrakt"

#: pretalx/cfp/templates/cfp/event/invitation.html
msgid "Accept invitation"
msgstr "Přijmout pozvánku"

#: pretalx/cfp/templates/cfp/event/login.html
msgid "Login"
msgstr "Přihlášení"

#: pretalx/cfp/templates/cfp/event/login.html
msgid "Welcome back!"
msgstr "Vítejte zpět!"

#: pretalx/cfp/templates/cfp/event/login.html
msgid ""
"You do not need an account to view the event, or submit feedback, or receive "
"schedule updates. You’ll only need an account if you participate in the "
"event as speaker or as an organiser."
msgstr ""
"Pro prohlížení této události, hodnocení přednášek ani aktualizace rozvrhu si "
"nepotřebujete zakládat žádný účet. Účet potřebujete jen pokud se této "
"události účastníte v roli přednášejícího nebo organizátora."

#: pretalx/cfp/templates/cfp/event/login.html
msgid ""
"If you already created a proposal for a different event on this server, you "
"can re-use your account to log in for this event."
msgstr ""
"Pokud jste už v minulosti poslali přihlášku na jinou událost na tomto "
"serveru, můžete využít stejné přihlašovací údaje i pro tuto událost."

#: pretalx/cfp/templates/cfp/event/recover.html
msgid "Set your password to access your profile and proposals"
msgstr "Nastavte heslo pro přístup k vašemu profilu a přihláškám"

#: pretalx/cfp/templates/cfp/event/submission_base.html
#: pretalx/orga/templates/orga/submission/content.html
msgid "Create proposal"
msgstr "Vytvořit přihlášku"

#: pretalx/cfp/templates/cfp/event/submission_base.html
msgid "Save as draft"
msgstr "Uložit jako koncept"

#: pretalx/cfp/templates/cfp/event/submission_base.html
#: pretalx/orga/templates/orga/cfp/editor.html
msgid "Continue"
msgstr "Pokračovat"

#: pretalx/cfp/templates/cfp/event/submission_base.html
#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Submit proposal"
msgstr "Odeslat přihlášku"

#: pretalx/cfp/templates/cfp/event/submission_base.html
msgid "or save as draft for now"
msgstr "nebo uložte jako koncept"

#: pretalx/cfp/templates/cfp/event/submission_base.html
msgid ""
"You can save your proposal as a draft and submit it later. Organisers will "
"not be able to see your proposal, though they will be able to send you "
"reminder emails about the upcoming deadline."
msgstr ""
"Svou přihlášku můžete uložit jako koncept a odeslat později. Organizátoři ho "
"neuvidí, ale mohou vám případně poslat e-mail s připomenutím termínu "
"uzávěrky."

#: pretalx/cfp/templates/cfp/event/submission_questions.html
#: pretalx/orga/templates/orga/cfp/editor.html
msgid "… about your proposal:"
msgstr "… o vaší přihlášce:"

#: pretalx/cfp/templates/cfp/event/submission_questions.html
#: pretalx/orga/templates/orga/cfp/editor.html
msgid "… about yourself:"
msgstr "… o vás:"

#: pretalx/cfp/templates/cfp/event/submission_user.html
msgid "Log in or register to save your draft"
msgstr "Pro uložení konceptu se přihlaste nebo zaregistrujte"

#: pretalx/cfp/templates/cfp/event/submission_user.html
msgid ""
"Organisers will not be able to see your draft or your email address. They "
"will be able to send you reminders about your pending proposal draft closer "
"to the deadline."
msgstr ""
"Organizátoři váš koncept ani e-mailovou adresu neuvidí. Mohou vám ale "
"případně poslat e-mail s připomenutím blížícího se termínu uzávěrky."

#: pretalx/cfp/templates/cfp/event/user_mails.html
msgid "Your Emails"
msgstr "Vaše e-maily"

#: pretalx/cfp/templates/cfp/event/user_mails.html
msgid ""
"These are emails the organisers sent you, so you should be able to find them "
"in your email inbox, but this page serves as a helper in case your email "
"address was unavailable or the emails got lost in some way."
msgstr ""
"Toto jsou e-maily, které vám poslali organizátoři, takže byste je měli najít "
"ve složce s doručenou poštou. Tato stránka slouží pro případ, že vaše e-"
"mailová adresa nebyla přístupná, nebo se e-maily ztratily někde po cestě."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Your Profile"
msgstr "Váš profil"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid ""
"This data will be displayed publicly if your proposal is accepted. It is "
"also visible to reviewers."
msgstr ""
"Tyto informace budou zobrazeny veřejně, pokud bude vaše přihláška přijata. "
"Budou také dostupné během kontroly."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "We have some questions"
msgstr "Máme pár otázek"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Your Account"
msgstr "Váš účet"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "You can change your login data here."
msgstr "Zde můžete změnit své přihlašovací údaje."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Account deletion"
msgstr "Smazání účtu"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid ""
"You can delete your account here – all names, emails, and other personal "
"information will be overwritten. <strong>This action is irreversible.</"
"strong>"
msgstr ""
"Tady můžete smazat svůj účet - všechna jména, e-maily a ostatní osobní údaje "
"budou smazány. <strong>Tato akce je nevratná.</strong>"

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid ""
"I really do want to delete my account, losing access to my proposals and "
"sessions, and overriding my public and private data."
msgstr ""
"Opravdu chci smazat svůj účet, ztratit přístup k mým přihláškám a přednáškám "
"a přepsat mé veřejné a soukromé informace přiřazené k tomuto účtu."

#: pretalx/cfp/templates/cfp/event/user_profile.html
msgid "Delete my account"
msgstr "Smazat můj účet"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm.html
msgid "Congratulations on your acceptance!"
msgstr "Gratulujeme k přijetí!"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm.html
msgid ""
"By confirming your proposal, you agree that you are able and willing to "
"participate in this event and present the content of this proposal. The "
"proposal data, such as title, abstract, description, and any uploads you "
"provided, can be made publicly available once the proposal is confirmed."
msgstr ""
"Potvrzením vaší přihlášky souhlasíte, že se můžete a chcete této události "
"zúčastni a odprezentovat navrženou přednášku. Informace v přihlášce, jako "
"například název, abstrakt, popis a všechny vámi nahrané soubory, budou v "
"případě přijetí přihlášky zveřejněny."

#: pretalx/cfp/templates/cfp/event/user_submission_confirm.html
msgid ""
"Please provide us with your available hours during the event, so that we can "
"schedule your session accordingly:"
msgstr ""
"Vyplňte prosím svou dostupnost během události, abychom mohli vaši přednášku "
"správně zařadit do programu:"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm_error.html
msgid "Proposal not found"
msgstr "Přihláška nenalezena"

#: pretalx/cfp/templates/cfp/event/user_submission_confirm_error.html
msgid ""
"The proposal you’re trying to confirm either does not exist or does not "
"belong to the account you’re currently logged in with. Try logging in with a "
"different account, or contact the event organisers for further information."
msgstr ""
"Přihláška, kterou se snažíte potvrdit, buď neexistuje, nebo nepatří účtu, "
"kterým jste se přihlásili. Zkuste se přihlásit jiným účtem nebo kontaktujte "
"organizátory."

#: pretalx/cfp/templates/cfp/event/user_submission_discard.html
msgid ""
"Do you really want to discard your draft proposal? All data will be lost."
msgstr ""
"Opravdu chcete zahodit koncept své přihlášky? Všechna její data budou "
"ztracena."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Confirm your attendance"
msgstr "Potvrdit svoji účast"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/orga/templates/orga/submission/feedback_list.html
#: pretalx/orga/templates/orga/submission/feedbacks_list.html
msgid "Attendee feedback"
msgstr "Zpětná vazba účastníků"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Attendees can leave feedback here after your session has taken place."
msgstr ""
"Návštěvníci zde budou moci vložit zpětnou vazbu, až se vaše přednáška "
"uskuteční."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Save draft"
msgstr "Uložit koncept"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Share proposal"
msgstr "Sdílet přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"If you need a review from a colleague or a friend here’s a link that you can "
"send out for viewing your proposal:"
msgstr ""
"Pokud chcete přihlášku zkontrolovat od kolegy nebo kamaráda, tady je odkaz k "
"jejímu zobrazení:"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/cfp/templates/cfp/event/user_submission_withdraw.html
msgid "Withdraw proposal"
msgstr "Stáhnout přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"You can withdraw your proposal from the selection process here. You cannot "
"undo this - if you are just uncertain if you can or should hold your "
"session, please contact the organiser instead."
msgstr ""
"Zde můžete stáhnout přihlášku z výběrového procesu. Tento krok ze nedá "
"vrátit - pokud se jen neumíte rozhodnout, zda přednášet či ne, kontaktujte "
"nejdříve organizátory."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/cfp/templates/cfp/event/user_submission_withdraw.html
#: pretalx/cfp/views/user.py
msgid "Withdraw"
msgstr "Stáhnout"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Discard draft proposal"
msgstr "Zahodit koncept přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"You can discard your draft proposal here. You cannot undo this - if you are "
"just uncertain if you can or should submit your proposal, please contact the "
"organiser instead."
msgstr ""
"Zde můžete zahodit koncept své přihlášky. Tento krok ze nedá vrátit - pokud "
"se jen neumíte rozhodnout, zda můžete nebo byste měli přihlášku odeslat, "
"kontaktujte nejdříve organizátory."

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
#: pretalx/orga/views/mails.py
msgid "Discard"
msgstr "Zahodit"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid "Cancel proposal"
msgstr "Zrušit přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submission_edit.html
msgid ""
"As your proposal has been accepted already, please contact the event’s "
"organisers to cancel it. The best way to reach out would be an answer to "
"your acceptance email."
msgstr ""
"Vaše přihláška už byla schválena, pro zrušení prosím kontaktujte "
"organizátory. Nejjednodušší je odpovědět na e-mail informující o přijetí "
"přihlášky."

#: pretalx/cfp/templates/cfp/event/user_submission_withdraw.html
msgid "Do you really want to withdraw your proposal?"
msgstr "Opravdu chcete stáhnout vaší přihlášku?"

#: pretalx/cfp/templates/cfp/event/user_submission_withdraw.html
msgid "You will not be able to revert this action."
msgstr "Nebudete moci vrátit tuto akci."

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Your proposals"
msgstr "Vaše přihlášky"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Important Information"
msgstr "Důležité informace"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Your drafts"
msgstr "Vaše koncepty"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Copy code for review"
msgstr "Zkopírovat kód pro hodnocení"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Edit draft"
msgstr "Upravit koncept"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Open draft"
msgstr "Otevřít koncept"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Edit proposal"
msgstr "Upravit přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Open proposal"
msgstr "Otevřít přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Create a new proposal"
msgstr "Vytvořit novou přihlášku"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "It seems like you haven’t submitted anything to this event yet."
msgstr "Zdá se, že jste zatím pro tuto událost nic nepřihlásili."

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "If you did, maybe you used a different account? Check your emails!"
msgstr ""
"Pokud tomu tak není, možná jste použili jiný účet? Zkontrolujte svoje e-"
"maily!"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid ""
"If you did not, why not go ahead and create a proposal now? We’d love to "
"hear from you!"
msgstr ""
"Pokud tomu tak je, proč si nevytvoříte přihlášku právě teď? Rádi o vás "
"uslyšíme!"

#: pretalx/cfp/templates/cfp/event/user_submissions.html
msgid "Submit something now!"
