#: pretalx/agenda/phrases.py
msgid "Thank you for your feedback!"
msgstr "Cảm ơn phản hồi của quý vị!"

#: pretalx/agenda/phrases.py
msgid "Thanks, we (and our speakers) appreciate your feedback!"
msgstr "Xin cảm ơn, Ban Tổ chức (và diễn giả) trân quý phản hồi của quý vị!"

#: pretalx/agenda/phrases.py
msgid "This session will not be recorded."
msgstr "Phiên này sẽ được ghi lại."

#: pretalx/agenda/phrases.py
msgid "View conference schedule"
msgstr "Xem chương trình hội thảo"

#: pretalx/agenda/phrases.py
msgid "View schedule preview"
msgstr "Xem trước chương trình"

#: pretalx/agenda/phrases.py
msgid "Edit or view your proposals"
msgstr "Sửa hoặc xem các đề xuất tham luận"

