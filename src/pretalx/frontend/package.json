{
  "name": "@pretalx/frontend",
  "version": "0.0.0",
  "description": "Frontend apps bundled with pretalx: the schedule editor and the public schedule.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev:editor": "vite",
    "dev:schedule": "vite",
    "build": "npm run build:manifest && npm run build:wc",
    "build:manifest": "vite build",
    "build:wc": "vite build --mode wc",
    "analyze": "ANALYZE=true vite build",
    "lint": "npm run lint:editor && npm run lint:schedule",
    "lint:editor": "cd schedule-editor && eslint .",
    "lint:schedule": "cd schedule && eslint src",
    "lint:fix": "cd schedule-editor && eslint . --fix && cd ../schedule && eslint src --fix",
    "i18n:extract": "cd schedule-editor && npx i18next-parser 'src/**/*.vue' -c i18next-parser.config.cjs",
    "i18n:convert2gettext": "cd schedule-editor && i18next-conv -l en -s locales/en/translation.json -t locales/en/translation.po"
  },
  "dependencies": {
    "buntpapier": "^2.0.0-alpha.34",
    "dompurify": "^3.3.0",
    "i18next": "^26.2.0",
    "lodash": "^4.18.1",
    "luxon": "^3.5.0",
    "markdown-it": "^14.2.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.48",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "~10.8.0",
    "eslint-plugin-vue-pug": "1.0.0-alpha.5",
    "i18next-conv": "^16.0.0",
    "i18next-parser": "^9.4.0",
    "pug": "^3.0.4",
    "stylus": "^0.64.0",
    "vite": "^8.0.14",
    "vite-bundle-visualizer": "^0.10.1"
  },
  "license": "Apache-2.0"
}
