// Shared layout geometry for the session card, used by both the public
// schedule and the schedule editor so the two render sessions identically.
//
// This is a stylus mixin (like buntpapier's border-separator() / ellipsis())
// and emits no CSS on its own: only the unconditional geometry that is
// byte-identical between both apps lives here. App-specific colour, state
// (drag/break/blocker/pending/condensed, fav, abstract, …) and the editor's
// per-state .time-box/.info treatment stay in each Session.vue.
session-layout()
	display: flex
	min-width: 300px
	min-height: 96px
	margin: 8px
	overflow: hidden
	position: relative
	.time-box
		// flex: none makes sure the fixed width is respected even against .info
		// overflowing
		flex: none
		width: 69px
		box-sizing: border-box
		padding: 12px 16px 8px 12px
		border-radius: 6px 0 0 6px
		display: flex
		flex-direction: column
		align-items: center
		.start
			font-size: 16px
			font-weight: 600
			margin-bottom: 8px
			display: flex
			flex-direction: column
			align-items: flex-end
			&.has-ampm
				align-self: stretch
			.ampm
				font-weight: 400
				font-size: 13px
	.info
		flex: auto
		display: flex
		flex-direction: column
		padding: 8px
		min-width: 0
		.title
			font-weight: 500
		.bottom-info
			flex: auto
			display: flex
			align-items: flex-end
			.track
				flex: 1
				color: var(--track-color)
				ellipsis()
				margin-right: 4px
